{
  "version": 2,
  "builds": [
    {
      "src": "api/index.py",
      "use": "@vercel/python",
      "config": { "maxLambdaSize": "15mb", "runtime": "python3.9" }
    }
  ],
  "routes": [
    {
      "src": "/static/(.*)",
      "dest": "/django_project/staticfiles/$1"
    },
    {
      "src": "/media/(.*)",
      "dest": "/django_project/media/$1"
    },
    {
      "src": "(.*)",
      "dest": "api/index.py"
    }
  ]
}
